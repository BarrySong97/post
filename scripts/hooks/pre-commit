#!/bin/sh
# @purpose 提交前 sensor:文档同步 + lint/test 的最后兜底(任何 AI 工具、甚至手工提交都生效)。
# @role    强制层(慢一点的层);与 AI 工具无关的 git 级闸门。
# 安装(二选一):
#   1) git config core.hooksPath scripts/hooks   且  chmod +x scripts/hooks/pre-commit
#   2) 用 lefthook / husky 调用本脚本
set -e
node scripts/check-docs.mjs

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
format_files=""
lint_files=""

for file in $staged_files; do
  case "$file" in
    *.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs|*.json|*.css)
      format_files="$format_files $file"
      ;;
  esac

  case "$file" in
    *.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs)
      lint_files="$lint_files $file"
      ;;
  esac
done

if [ -n "$format_files" ]; then
  pnpm exec oxfmt --check $format_files --no-error-on-unmatched-pattern
fi

if [ -n "$lint_files" ]; then
  pnpm exec oxlint $lint_files --no-error-on-unmatched-pattern
fi
