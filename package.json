{
  "name": "post",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm rebuild:electron && turbo -F desktop dev",
    "dev:website": "pnpm -F website dev",
    "build": "turbo build",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "lint": "oxlint apps packages scripts --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint apps packages scripts --fix --no-error-on-unmatched-pattern",
    "format": "oxfmt --write apps packages scripts package.json tsconfig.json turbo.json .claude .codex .oxlintrc.json .oxfmtrc.json --no-error-on-unmatched-pattern",
    "format:check": "oxfmt --check apps packages scripts package.json tsconfig.json turbo.json .claude .codex .oxlintrc.json .oxfmtrc.json --no-error-on-unmatched-pattern",
    "db:generate": "pnpm -F @post/db db:generate",
    "db:migrate": "pnpm -F @post/db db:migrate",
    "db:studio": "pnpm -F @post/db db:studio",
    "post-cli": "pnpm -F @post/cli post-cli",
    "perf:seed-assets": "node scripts/perf/seed-asset-fixture.mjs",
    "perf:measure-assets": "node scripts/perf/measure-asset-list.mjs",
    "ffmpeg:prepare": "node scripts/prepare-ffmpeg.mjs",
    "indexer:build": "cargo build -p post-indexer --release",
    "indexer:check": "cargo check -p post-indexer",
    "indexer:test": "cargo test -p post-indexer",
    "package": "pnpm ffmpeg:prepare && pnpm indexer:build && pnpm -F desktop package",
    "dist": "pnpm ffmpeg:prepare && pnpm indexer:build && pnpm -F desktop dist",
    "release": "node scripts/release.mjs",
    "rebuild:electron": "node_modules/.pnpm/node_modules/.bin/electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
