{
  "name": "desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Electron desktop app scaffold for Post",
  "author": "Post",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:debug": "OPEN_DEVTOOLS=1 electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "check-types": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "package": "electron-vite build && electron-builder --dir --config electron-builder.yml",
    "dist": "electron-vite build && electron-builder --config electron-builder.yml"
  },
