{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["env.d.ts", "src/renderer/src/**/*", "src/shared/**/*", "src/preload/*.d.ts"],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*"],
      "@renderer/*": ["src/renderer/src/*"],
      "@main/*": ["src/main/*"],
      "@shared/*": ["src/shared/*"],
      "@post/ui/*": ["../../packages/ui/src/*"],
      "@post/db": ["../../packages/db/src/index.ts"],
      "@post/db/*": ["../../packages/db/src/*"]
    }
  }
}
