{
  "manifest_version": 3,
  "name": "Post",
  "description": "Collect assets for Post from the browser.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["contextMenus", "nativeMessaging", "webRequest", "storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "https://video.twimg.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content/twitter-video-context.ts"],
      "run_at": "document_idle"
    }
  ]
}
