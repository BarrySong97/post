# Cloudflare R2 凭据 —— 复制本文件为 .env 并填入真实值(.env 已被 .gitignore 忽略,勿提交)
#   cp .env.example .env
# 这些值供 scripts/img.mjs 上传压缩后的博客图片到 R2。
# 在 Cloudflare 控制台 → R2 → Manage R2 API Tokens 生成 Access Key。

# R2 账户 ID(Cloudflare 控制台右侧,或 R2 概览页)
R2_ACCOUNT_ID=

# R2 API Token 的 Access Key ID / Secret Access Key
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# 目标存储桶名
R2_BUCKET=

# 图片对外公开访问的基础域名(不带结尾斜杠),如自定义域 https://blogassets.4real.ink
# 或 R2 公共开发域名 https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE=https://blogassets.4real.ink

# 上传到桶内的 key 前缀(可选,默认 blog)
R2_KEY_PREFIX=blog
